{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telegram-transcriber.local/contracts/schemas/common/error-envelope.schema.json",
  "title": "ErrorEnvelope",
  "type": "object",
  "required": [
    "error"
  ],
  "properties": {
    "error": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
